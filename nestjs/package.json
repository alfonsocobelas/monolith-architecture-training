{
  "name": "monolith-arch-nestjs",
  "version": "1.0.0",
  "description": "Monolith Architecture with NestJS example",
  "author": "Alfonso Cobelas",
  "license": "ISC",
  "keywords": [
    "monolith",
    "architecture",
    "nestjs"
  ],
  "main": "dist/src/start.js",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.3"
  },
  "scripts": {
    "build": "nest build",
    "commit": "cz",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests --ext .js,.ts",
    "lint:fix": "npm run lint --fix",
    "prepare": "husky",
    "start": "nest start",
    "start:dev": "NODE_ENV=dev nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=prod node dist/src/start.js",
    "test": "jest",
    "test:unit": "NODE_ENV=test JEST_ENV='unit' jest",
    "test:integration": "NODE_ENV=test JEST_ENV='integration' jest --runInBand",
    "test:acceptance": "NODE_ENV=test cucumber-js -p monolithArchNestjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/data-source.ts"
  },
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "nyc": {
    "exclude": [
      "tests/**",
      "**/*.test.ts",
      "**/mocks/**",
      "**/dto/**",
      "commitlint.config.js",
      "cucumber.js",
      "jest.config.js",
      "**/coverage/**",
      "**/enums.ts",
      "**/schemas/**",
      "**/controllers/**",
      "**/routes/**",
      "**/routes/**",
      "**/common/**",
      "**/index.ts",
      "**/start.ts",
      "**/app.ts",
      "**/server.ts"
    ],
    "reporter": [
      "lcov",
      "text",
      "html"
    ],
    "report-dir": "./coverage/acceptance",
    "all": true,
    "check-coverage": true,
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 70
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cucumber/cucumber": "^12.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@stylistic/eslint-plugin": "^5.3.1",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "chai": "^6.2.2",
    "commitizen": "^4.3.1",
    "cpx": "^1.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.2.2",
    "fast-check": "^4.5.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.6",
    "nyc": "^17.1.0",
    "prettier": "^3.4.2",
    "sinon": "^21.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.57.1"
  }
}
