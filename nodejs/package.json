{
  "name": "monolith-arch-nodejs",
  "version": "1.0.0",
  "description": "Monolith Architecture with NodeJS example",
  "author": "Alfonso Cobelas",
  "license": "ISC",
  "keywords": [
    "monolith",
    "architecture",
    "nodejs"
  ],
  "main": "dist/src/start.js",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.3"
  },
  "scripts": {
    "build": "npm run build:clean && npm run build:tsc && npm run build:di",
    "build:clean": "rm -r dist; exit 0",
    "build:tsc": "tsc -p tsconfig.build.json",
    "build:di": "cpx \"src/**/*.{json,yaml,html,png}\" dist/src",
    "commit": "cz",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests --ext .js,.ts",
    "lint:fix": "eslint src tests --ext .js,.ts --fix",
    "prepare": "husky",
    "start:local": "NODE_ENV=local ts-node-dev -r tsconfig-paths/register --ignore-watch node_modules ./src/start.ts",
    "start:dev": "NODE_ENV=dev ts-node-dev -r tsconfig-paths/register --ignore-watch node_modules ./src/start.ts",
    "start:qa": "NODE_ENV=qa node dist/src/start",
    "start:prod": "NODE_ENV=prod node dist/src/start",
    "test": "npm run test:unit &&  npm run test:integration && npm run test:acceptance",
    "test:unit": "NODE_ENV=test JEST_ENV='unit' jest",
    "test:integration": "NODE_ENV=test JEST_ENV='integration' jest --runInBand",
    "test:acceptance": "NODE_ENV=test cucumber-js -p monolithArchNodejs",
    "clear:test:unit": "NODE_ENV=test JEST_ENV='unit' jest --clearCache",
    "debug:test:unit": "NODE_ENV=test JEST_ENV='unit' JEST_SEED=$SEED jest --runInBand --watch",
    "debug:test:integration": "NODE_ENV=test JEST_ENV='integration' JEST_SEED=$SEED jest --runInBand --watch",
    "coverage": "npm run coverage:clean && npm run coverage:unit-integration && npm run coverage:acceptance",
    "coverage:clean": "rm -rf .nyc_output coverage",
    "coverage:acceptance": "nyc npm run test:acceptance",
    "coverage:unit-integration": "jest --coverage --testMatch '<rootDir>/tests/modules/**/*.test.ts' '<rootDir>/tests/infrastructure/**/*.test.ts' --coverageDirectory=coverage/unit-integration",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:migration:generate": "NODE_ENV=local npm run typeorm migration:generate -- -d ./src/infrastructure/persistence/typeorm/typeorm-data-source.ts",
    "typeorm:migration:create": "NODE_ENV=local npm run typeorm migration:create",
    "typeorm:migration:run": "npm run typeorm migration:run -- -d ./src/infrastructure/persistence/typeorm/typeorm-data-source.ts",
    "typeorm:migration:rollback": "npm run typeorm migration:revert -- -d ./src/infrastructure/persistence/typeorm/typeorm-data-source.ts",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:ci": "npm audit --audit-level=high"
  },
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "nyc": {
    "exclude": [
      "tests/**",
      "**/*.test.ts",
      "**/mocks/**",
      "**/dto/**",
      "commitlint.config.js",
      "cucumber.js",
      "jest.config.js",
      "**/coverage/**",
      "**/enums.ts",
      "**/schemas/**",
      "**/controllers/**",
      "**/routes/**",
      "**/routes/**",
      "**/common/**",
      "**/index.ts",
      "**/start.ts",
      "**/app.ts",
      "**/server.ts"
    ],
    "reporter": [
      "lcov",
      "text",
      "html"
    ],
    "report-dir": "./coverage/acceptance",
    "all": true,
    "check-coverage": true,
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 70
  },
  "dependencies": {
    "bson": "^6.10.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "convict": "^6.2.4",
    "express": "^5.1.0",
    "glob": "^11.0.3",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "node-dependency-injection": "^3.2.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cucumber/cucumber": "^12.2.0",
    "@eslint/js": "^9.34.0",
    "@faker-js/faker": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.3.1",
    "@types/chai": "^5.2.3",
    "@types/compression": "^1.8.1",
    "@types/convict": "^6.1.6",
    "@types/express": "^5.0.3",
    "@types/glob": "^8.1.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.2",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "chai": "^6.2.2",
    "commitizen": "^4.3.1",
    "cpx": "^1.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.34.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "fast-check": "^4.5.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.6",
    "nyc": "^17.1.0",
    "prettier": "^3.6.2",
    "sinon": "^21.0.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}