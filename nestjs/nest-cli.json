{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "start",
  "language": "ts",
  "monorepo": false,
  "generateOptions": {
    "spec": false
  },
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "./tsconfig.build.json",
    "webpack": false,
    "assets": [
      {
        "include": "src/infrastructure/config/environments/**/*",
        "outDir": "dist/src/infrastructure/config/environments"
      }
    ],
    "watchAssets": false,
    "plugins": []
  }
}